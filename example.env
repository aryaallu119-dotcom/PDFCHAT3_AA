# =========================================================

# PDF Chatbot - Environment Variables

# Rename this file to .env (or app.env as required)

# and replace the placeholder values with your own.

# =========================================================

# ----------------------------

# Groq API

# ----------------------------

GROQ_API_KEY=your_groq_api_key

# ----------------------------

# Hugging Face

# ----------------------------

HF_TOKEN=your_huggingface_token< if required >

# ----------------------------

# MongoDB Atlas

# ----------------------------

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/?retryWrites=true&w=majority&appName=<app-name>

# ----------------------------

# Cloudinary

# ----------------------------

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
